<?xml version="1.0" encoding="utf-8"?>
<!-- 높이는 wrap_content. 줄이 없으면 흰 카드가 그만큼 줄어들고 나머지는 투명해진다. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/widget_bg"
    android:padding="12dp">

    <TextView
        android:id="@+id/w_head"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="6dp"
        android:textSize="11sp"
        android:textStyle="bold"
        android:textColor="#99A0B2"
        android:maxLines="1"
        android:ellipsize="end"
        android:text="오늘 할 복습" />

    <LinearLayout
        android:id="@+id/w_row0"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="1dp"
        android:paddingBottom="1dp">

        <ImageView
            android:id="@+id/w_dot0"
            android:layout_width="5dp"
            android:layout_height="5dp"
            android:layout_marginEnd="7dp"
            android:background="#2E3A5C" />

        <TextView
            android:id="@+id/w_lab0"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="30dp"
            android:textSize="11sp"
            android:textColor="#2E3A5C"
            android:text="신규" />

        <TextView
            android:id="@+id/w_num0"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="7dp"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#14172A"
            android:text="—" />

        <TextView
            android:id="@+id/w_tt0"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:layout_marginStart="7dp"
            android:textSize="11sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:textColor="#99A0B2"
            android:text="" />

        <TextView
            android:id="@+id/w_chk0"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:gravity="center"
            android:textSize="16sp"
            android:text="○" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/w_row1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="1dp"
        android:paddingBottom="1dp">

        <ImageView
            android:id="@+id/w_dot1"
            android:layout_width="5dp"
            android:layout_height="5dp"
            android:layout_marginEnd="7dp"
            android:background="#0B6E78" />

        <TextView
            android:id="@+id/w_lab1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="30dp"
            android:textSize="11sp"
            android:textColor="#0B6E78"
            android:text="1일" />

        <TextView
            android:id="@+id/w_num1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="7dp"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#14172A"
            android:text="—" />

        <TextView
            android:id="@+id/w_tt1"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:layout_marginStart="7dp"
            android:textSize="11sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:textColor="#99A0B2"
            android:text="" />

        <TextView
            android:id="@+id/w_chk1"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:gravity="center"
            android:textSize="16sp"
            android:text="○" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/w_row2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="1dp"
        android:paddingBottom="1dp">

        <ImageView
            android:id="@+id/w_dot2"
            android:layout_width="5dp"
            android:layout_height="5dp"
            android:layout_marginEnd="7dp"
            android:background="#9A5B00" />

        <TextView
            android:id="@+id/w_lab2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="30dp"
            android:textSize="11sp"
            android:textColor="#9A5B00"
            android:text="1주" />

        <TextView
            android:id="@+id/w_num2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="7dp"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#14172A"
            android:text="—" />

        <TextView
            android:id="@+id/w_tt2"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:layout_marginStart="7dp"
            android:textSize="11sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:textColor="#99A0B2"
            android:text="" />

        <TextView
            android:id="@+id/w_chk2"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:gravity="center"
            android:textSize="16sp"
            android:text="○" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/w_row3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="1dp"
        android:paddingBottom="1dp">

        <ImageView
            android:id="@+id/w_dot3"
            android:layout_width="5dp"
            android:layout_height="5dp"
            android:layout_marginEnd="7dp"
            android:background="#6E3691" />

        <TextView
            android:id="@+id/w_lab3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="30dp"
            android:textSize="11sp"
            android:textColor="#6E3691"
            android:text="1달" />

        <TextView
            android:id="@+id/w_num3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="7dp"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#14172A"
            android:text="—" />

        <TextView
            android:id="@+id/w_tt3"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:layout_marginStart="7dp"
            android:textSize="11sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:textColor="#99A0B2"
            android:text="" />

        <TextView
            android:id="@+id/w_chk3"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:gravity="center"
            android:textSize="16sp"
            android:text="○" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/w_row4"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="1dp"
        android:paddingBottom="1dp">

        <ImageView
            android:id="@+id/w_dot4"
            android:layout_width="5dp"
            android:layout_height="5dp"
            android:layout_marginEnd="7dp"
            android:background="#C0362C" />

        <TextView
            android:id="@+id/w_lab4"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="30dp"
            android:textSize="11sp"
            android:textColor="#C0362C"
            android:text="다시" />

        <TextView
            android:id="@+id/w_num4"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="7dp"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#14172A"
            android:text="—" />

        <TextView
            android:id="@+id/w_tt4"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:layout_marginStart="7dp"
            android:textSize="11sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:textColor="#99A0B2"
            android:text="" />

        <TextView
            android:id="@+id/w_chk4"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:gravity="center"
            android:textSize="16sp"
            android:text="○" />
    </LinearLayout>

    <TextView
        android:id="@+id/w_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:textSize="12sp"
        android:textColor="#99A0B2"
        android:visibility="gone"
        android:text="오늘 할 복습이 없습니다" />

</LinearLayout>
